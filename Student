from pytorch_wavelets import DWTForward, DWTInverse
import torch.optim as optim


# Prompt-Guided Router (PGR)
class PromptGuidedRouter(nn.Module):
    """
    Replaces GAP->MLP softmax in MGIF with prompt-driven routing.
    - Keeps params tiny: prompts (K x C), and a small mapper to 3 branch weights.
    - Cosine-sim from pooled token to prompt bank => soft attention over prompts.
    - Aggregated prompt vector -> 3-way gating (pixel/local/global).
    """

    def __init__(self, channels, num_prompts=16, hidden=64):  # on the first attempt num_promts= 8 Now changing to 16
        super().__init__()
        self.num_prompts = num_prompts
        # Prompt bank: learnable "instruction" vectors
        self.prompts = nn.Parameter(torch.randn(num_prompts, channels))
        nn.init.normal_(self.prompts, std=0.02)

        # Map aggregated prompt context -> 3 weights
        self.mapper = nn.Sequential(
            nn.Linear(channels, hidden, bias=False),
            nn.ReLU(inplace=True),
            nn.Linear(hidden, 3)
        )

    def forward(self, x):  # x: (B, C, H, W) after fusion sum or pooled token producer
        B, C, H, W = x.shape
        # global token
        g = F.adaptive_avg_pool2d(x, 1).flatten(1)  # (B, C)
        # cosine sim to prompt bank
        g_n = F.normalize(g, dim=1)  # (B, C)
        p_n = F.normalize(self.prompts, dim=1)  # (K, C)
        sim = torch.matmul(g_n, p_n.t()) / 0.07  # (B, K) --> changing the sim by adding temperature temperature τ=0.07
        a = F.softmax(sim, dim=1)  # prompt attention
        # aggregate prompt vector
        p_ctx = torch.matmul(a, self.prompts)  # (B, C)
        w = self.mapper(p_ctx)  # (B, 3)
        w = F.softmax(w, dim=1).view(B, 3, 1, 1)  # (B,3,1,1)
        return w[:, 0:1], w[:, 1:2], w[:, 2:3]  # wa, wb, wc


class GlobalDWTBranch(nn.Module):
    def __init__(self, in_channels, out_channels):
        super(GlobalDWTBranch, self).__init__()
        self.dwt = DWTForward(J=1, wave='haar')
        self.idwt = DWTInverse(wave='haar')

        self.project_in = nn.Conv2d(in_channels, out_channels, kernel_size=1, bias=False)

        self.dwconv_ll = nn.Sequential(
            nn.Conv2d(out_channels, out_channels, kernel_size=3, padding=1, groups=out_channels),
            nn.ReLU(),
            nn.Conv2d(out_channels, out_channels, kernel_size=3, padding=1, groups=out_channels),
        )

        self.dwconv_hh = nn.Sequential(
            nn.Conv2d(out_channels, out_channels, kernel_size=3, padding=1, groups=out_channels),
            nn.ReLU(),
            nn.Conv2d(out_channels, out_channels, kernel_size=3, padding=1, groups=out_channels),
        )

    def forward(self, x):
        x = self.project_in(x)  # Ensure correct number of channels before DWT
        Yl, Yh = self.dwt(x)
        LH = Yh[0][:, :, 0, :, :]
        HL = Yh[0][:, :, 1, :, :]
        HH = Yh[0][:, :, 2, :, :]

        # Low  level path
        Yl_mod = self.dwconv_ll(Yl)

        # High-bands path with dir-attn + shrinkage
        # original saved model 4
        HH_combined = (LH + HL + HH) / 3.0
        HH_mod = self.dwconv_hh(HH_combined)

        Yh_mod = torch.stack([HH_mod, HH_mod, HH_mod], dim=2)
        out = self.idwt((Yl_mod, [Yh_mod]))
        return out


class MGIFBlock(nn.Module):
    def __init__(self, in_channels, out_channels, num_prompts=8):
        super().__init__()

        self.pixel_branch = nn.Sequential(
            nn.Conv2d(in_channels, out_channels, kernel_size=1, bias=False),
            nn.BatchNorm2d(out_channels),
            nn.ReLU(inplace=True)
        )

        self.local_branch = nn.Sequential(
            nn.Conv2d(in_channels, in_channels, kernel_size=3, padding=1, groups=in_channels, bias=False),
            nn.ReLU(inplace=True),
            nn.Conv2d(in_channels, out_channels, kernel_size=1, bias=False),
            nn.BatchNorm2d(out_channels),
            nn.ReLU(inplace=True)
        )

        self.global_branch = GlobalDWTBranch(in_channels, out_channels)

        # self.gap_fc = nn.Sequential(
        #     nn.AdaptiveAvgPool2d(1),
        #     nn.Conv2d(out_channels, out_channels // 4, 1),
        #     nn.ReLU(),
        #     nn.Conv2d(out_channels // 4, 3, 1),
        #     nn.Softmax(dim=1)
        # )
        # I am replacing gap_FC with PromptguiderRouter

        # ✨ New: prompt-guided router instead of GAP->conv->softmax(3)
        self.router = PromptGuidedRouter(out_channels, num_prompts=num_prompts, hidden=max(32, out_channels // 8))

        self.fuse = nn.Sequential(
            nn.Conv2d(out_channels, out_channels, kernel_size=1),
            nn.ReLU(inplace=True)
        )

    def forward(self, x):
        a = self.pixel_branch(x)
        b = self.local_branch(x)
        c = self.global_branch(x)

        F_sum = a + b + c
        # weights = self.gap_fc(F_sum)
        wa, wb, wc = self.router(F_sum)

        # wa = weights[:, 0:1, :, :]
        # wb = weights[:, 1:2, :, :]
        # wc = weights[:, 2:3, :, :]

        fused = a * wa + b * wb + c * wc
        return self.fuse(fused)


