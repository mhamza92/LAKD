class AFF(nn.Module):
    def __init__(self, channels, kernel_size=3):
        super(AFF, self).__init__()

        self.conv = nn.Conv2d(2 * channels, 2, kernel_size=3, padding=kernel_size // 2)

    def forward(self, XL, XG):
        """
               Forward pass for adaptive feature fusion.

               Args:
                   XL (Tensor): Local feature map of shape (B, C, H, W).
                   XG (Tensor): Global feature map of shape (B, C, H, W).

               Returns:
                   Tensor: Adaptive output feature map of shape (B, C, H, W).
               """
        # Concatenate XL and XG along the channel dimension
        Y = torch.cat((XL, XG), dim=1)  # Shape: (B, 2C, H, W)

        # Apply convolution and softmax to obtain weights
        W = self.conv(Y)  # Shape: (B, 2, H, W)
        W = F.softmax(W, dim=1)  # Apply softmax along the channel dimension

        # Separate the weights into local (WL) and global (WG)
        WL, WG = torch.split(W, 1, dim=1)  # Shapes: (B, 1, H, W), (B, 1, H, W)

        # Apply the weights to the original feature maps and combine
        A = WL * XL + WG * XG  # Elementwise multiplication and addition

        return A


