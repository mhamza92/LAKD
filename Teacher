class CombinedModel(nn.Module):
    def __init__(self, nc, prompt_length=5):
        super(CombinedModel, self).__init__()
        self.cnn = net1  # Modified RCA_Net that outputs features
        self.swin_transformer = trans_model
        # Assuming the output feature sizes from both models are compatible
        self.conv3 = nn.Conv2d(960, 768, kernel_size=1)
        # Average pooling to reduce spatial dimensions
        self.avg_pool = nn.AdaptiveAvgPool2d((1, 1))

        # Add the AFF module
        self.feature_fusion_module = AFF(channels=768)  # Use the correct number of channels

        # self.norm=nn.BatchNorm2d(768)
        # self.relu=nn.ReLU6()

        # Define new MLP for final classification
        self.mlp = nn.Sequential(
            nn.Linear(768, 1024),
            # nn.Linear(cnn_output_size+swin_output_size, 1024),
            nn.ReLU6(),
            nn.Linear(1024, nc)
        )

        # Freeze CNN weights
        for param in self.cnn.parameters():
            param.requires_grad = False
            # Freeze CNN weights
        for param in self.swin_transformer.parameters():
            param.requires_grad = False

        for param in self.conv3.parameters():
            param.requires_grad = False

    def forward(self, x):
        cnn_output = self.cnn(x)  # Output: [batch_size, 1280]
        cnn_output = self.conv3(cnn_output)  # (B, 768, Hc, Wc)
        cnn_spatial = cnn_output
        swin_output = self.swin_transformer(x)  # (B, 768, Hs, Ws)
        # swin_spatial = swin_output
        swin_sp = swin_output

        target_hw = swin_sp.shape[-2:]
        cnn_sp = F.interpolate(cnn_spatial, size=target_hw, mode='bilinear', align_corners=False)

        # spatial fusion (no pooling BEFORE fusion)
        fused_spatial = self.feature_fusion_module(cnn_sp, swin_sp)  # (B,768,H,W)
        #fused_spatial = cnn_sp+swin_sp
        # logits for teacher (optional, used by logit KD if you keep it)
        pooled = self.avg_pool(fused_spatial).flatten(1)  # (B,768)
        logits = self.mlp(pooled)

        # we only *need* feat_fused for KD
        return logits, {"feat_fused": fused_spatial}
